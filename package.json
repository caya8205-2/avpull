{
  "name": "avpull",
  "version": "0.4.0",
  "description": "Download audio/video from YouTube, convert directly to your chosen format (mp3, wav, mp4, etc.)",
  "type": "module",
  "bin": {
    "avpull": "./bin/avpull.js"
  },
  "main": "src/cli.js",
  "author": "caya8205-2",
  "license": "MIT",
  "keywords": [
    "youtube",
    "downloader",
    "converter",
    "audio",
    "video",
    "mp3",
    "mp4",
    "cli",
    "ffmpeg",
    "youtubei"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caya8205-2/avpull.git"
  },
  "bugs": {
    "url": "https://github.com/caya8205-2/avpull/issues"
  },
  "homepage": "https://caya8205-2.github.io/avpull",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build --compile --target=bun --outfile=dist/avpull ./bin/avpull.js",
    "release": "bun run build && node scripts/copy-ffmpeg.js",
    "release:version": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1",
    "prepublishOnly": "echo 'Ready to publish to npm'",
    "version:sync": "bun scripts/sync-version.js"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "ffmpeg-static": "^5.3.0",
    "picocolors": "^1.1.1",
    "youtubei.js": "^17.2.0"
  }
}
